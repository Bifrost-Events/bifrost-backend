# staging – automatisk quality (resetbar database)
APP_ENV=staging
APP_DEBUG=false
APP_NAME=Bifrost API

STORAGE_DRIVER=pdo
DB_DSN=mysql:host=127.0.0.1;dbname=bifrost_quality_staging;charset=utf8mb4
DB_USER=CHANGE_ME
DB_PASS=CHANGE_ME

# Playwright reset-endepunkt (POST /deploy/reset-staging)
STAGING_DEPLOY_SECRET=CHANGE_ME_LONG_RANDOM
QUALITY_RESET_DATABASE=true
QUALITY_SEED_DATABASE=true
# Ekstra sikring: database-navn må inneholde "staging", eller sett true eksplisitt:
ALLOW_STAGING_RESET=true

# Valgfritt – default database/migrations og database/seeds i deploy-pakken
# MIGRATIONS_PATH=
# SEEDS_PATH=
